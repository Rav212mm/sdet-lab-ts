{
  "name": "@sdet-lab/ui-tests",
  "version": "1.0.0",
  "scripts": {
    "test": "cucumber-js --format progress",
    "test:smoke": "cucumber-js --format progress --tags @smoke",
    "test:regression": "cucumber-js --format progress --tags @regression",
    "report": "allure generate allure-results -o allure-report --clean && allure open allure-report"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.1.1",
    "@faker-js/faker": "^9.3.0",
    "allure-cucumberjs": "^3.0.4",
    "playwright": "^1.49.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.7"
  }
}